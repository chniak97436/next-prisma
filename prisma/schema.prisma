generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                   Int        @id @default(autoincrement())
  username             String
  email                String     @unique
  emailVerified        DateTime?
  password_hash        String
  first_name           String?
  last_name            String?
  address              String?
  phone                String?
  role                 String     @default("customer")
  created_at           DateTime   @default(now())
  resetPasswordToken   String?    @unique
  resetPasswordExpires DateTime?
  avis                 Avis[]
  commande             Commande[]

  @@map("users")
}

model Category {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String?
  parent_id   Int?
  parent      Category?  @relation("CategoryHierarchy", fields: [parent_id], references: [id], onDelete: Cascade)
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]

  @@map("categories")
}

model Product {
  id             Int            @id @default(autoincrement())
  name           String
  description    String?
  price          Float
  stock_quantity Int            @default(0)
  category_id    Int?
  image_url      String?
  created_at     DateTime       @default(now())
  avis           Avis[]
  commande_items CommandeItem[]
  category       Category?      @relation(fields: [category_id], references: [id])

  @@map("products")
}

model Commande {
  id               Int            @id @default(autoincrement())
  user_id          Int
  total_amount     Float
  status           String         @default("attente")
  shipping_address String?
  created_at       DateTime       @default(now())
  user             User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  commande_items   CommandeItem[]
  payment          Payment?

  @@map("commande")
}

model CommandeItem {
  id          Int      @id @default(autoincrement())
  commande_id Int
  product_id  Int
  quantity    Int
  unit_price  Float
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  commande    Commande @relation(fields: [commande_id], references: [id], onDelete: Cascade)

  @@map("commande_items")
}

model Payment {
  id             Int      @id @default(autoincrement())
  commande_id    Int      @unique
  payment_method String
  amount         Float
  status         String   @default("attente")
  transaction_id String?
  created_at     DateTime @default(now())
  commande       Commande @relation(fields: [commande_id], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Avis {
  id         Int      @id @default(autoincrement())
  user_id    Int
  product_id Int
  note       Int
  comment    String?
  created_at DateTime @default(now())
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("avis")
}

model Newsletter {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  subscribed_at   DateTime  @default(now())
  promoCode       String    @default("WELCOME10")
  promoCodeUsed   Boolean   @default(false)
  promoCodeUsedAt DateTime?

  @@map("newsletters")
}
